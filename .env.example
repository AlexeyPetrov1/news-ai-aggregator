# =============================================================================
# Шаблон для Docker Compose (скопируйте: cp .env.example .env)
# Секреты подставьте в .env — этот файл можно коммитить в git.
# =============================================================================

# --- Порты на хосте (опционально) ---
TTRSS_PORT=8080
SHINY_PORT=3838
MCP_PORT=8000
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000

# --- TT-RSS ---
# Для R-скриптов на вашем компьютере (когда compose уже запущен):
TTRSS_URL=http://localhost:8080
TTRSS_USER=admin
TTRSS_PASSWORD=password
TTRSS_ADMIN_USER=admin
TTRSS_ADMIN_PASSWORD=password
# Пароль PostgreSQL для TT-RSS (сервис ttrss-db)
TTRSS_DB_PASSWORD=ttrss_secret

# Внутри Docker scheduler/shiny используют TTRSS_URL=http://ttrss/ из docker-compose.yml

# --- ClickHouse ---
CH_HOST=clickhouse
CH_PORT=9000
CH_DB=ttrss
CH_USER=default
CH_PASSWORD=

# --- Сбор данных ---
MAX_ARTICLES=500
SCHEDULER_INTERVAL_SECONDS=3600

# --- Классификация (по умолчанию lda, без внешних API) ---
CLASSIFY_METHOD=lda
N_TOPICS=8

# --- Scheduler: инициализация RSS-фидов ---
INIT_FEEDS_ON_START=true
INIT_FEEDS_RETRY_MAX=5
INIT_FEEDS_RETRY_DELAY_SECONDS=30
CONTINUE_ON_FEEDS_INIT_ERROR=true
RUN_ADD_FEEDS_EACH_CYCLE=false

# --- Yandex GPT (раскомментируйте при CLASSIFY_METHOD=yandex_llm) ---
# CLASSIFY_METHOD=yandex_llm
# YANDEX_CLOUD_API_KEY=
# YANDEX_CLOUD_FOLDER=
# YANDEX_CLOUD_MODEL=yandexgpt-5-lite/latest
# YANDEX_CLOUD_BASE_URL=https://ai.api.cloud.yandex.net/v1
# YANDEX_CACHE_PATH=data/yandex_llm_cache.rds

# --- Универсальный LLM / ellmer (раскомментируйте при CLASSIFY_METHOD=llm) ---
# CLASSIFY_METHOD=llm
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
